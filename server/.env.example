# Server binding. Default app binding is 0.0.0.0; restrict network exposure at firewall/reverse proxy if needed.
HOST=0.0.0.0
PORT=29999
CORS_ALLOW_ORIGIN=http://127.0.0.1:29999

# Required in production. Dev/test fallback only: dev-api-key.
BRIDGE_API_KEYS=change-me-long-random-token

# Optional admin login bootstrap.
AUTH_ADMIN_USERNAME=admin
AUTH_ADMIN_PASSWORD=change-me-at-least-8-chars
AUTH_COOKIE_SECURE=1

# OpenClaw integration.
OPENCLAW_TRANSPORT=gateway-openai
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=change-me
OPENCLAW_GATEWAY_MODEL=openclaw

# Optional PWA wallet metadata.
VITE_REOWN_PROJECT_ID=
VITE_APP_ORIGIN=http://127.0.0.1:29999
VITE_APP_NAME=OpenClaw
VITE_APP_DESCRIPTION=OpenClaw Custom Channel
