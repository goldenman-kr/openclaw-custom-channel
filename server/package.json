{
  "name": "server",
  "version": "1.0.0",
  "description": "모바일 앱과 OpenClaw 사이를 연결하는 브릿지 서버 구현 디렉토리입니다.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "npm run build:ts && npm run build:pwa:spot",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "smoke:token-sse": "node scripts/smoke-token-sse.mjs",
    "smoke:gateway-openai": "node scripts/smoke-gateway-openai.mjs",
    "smoke:bridge-gateway-openai": "node scripts/smoke-bridge-gateway-openai.mjs",
    "user:list": "tsx scripts/user-admin.ts list",
    "user:create": "tsx scripts/user-admin.ts create",
    "user:reset-password": "tsx scripts/user-admin.ts reset-password",
    "user:disable": "tsx scripts/user-admin.ts disable",
    "user:enable": "tsx scripts/user-admin.ts enable",
    "restart-followup:schedule": "tsx scripts/schedule-restart-followup.ts",
    "build:pwa:spot": "vite build --config vite.spot.config.mjs",
    "build:ts": "tsc -p tsconfig.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "@reown/appkit": "^1.8.19",
    "@reown/appkit-adapter-wagmi": "^1.8.19",
    "@tanstack/react-query": "^5.100.9",
    "better-sqlite3": "^12.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "undici": "^6.24.1",
    "viem": "^2.48.8",
    "wagmi": "^3.6.9"
  },
  "overrides": {
    "axios": "^1.16.0"
  }
}
