{
  "name": "server",
  "version": "1.0.0",
  "description": "모바일 앱과 OpenClaw 사이를 연결하는 브릿지 서버 구현 디렉토리입니다.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "smoke:token-sse": "node scripts/smoke-token-sse.mjs",
    "smoke:gateway-openai": "node scripts/smoke-gateway-openai.mjs",
    "smoke:bridge-gateway-openai": "node scripts/smoke-bridge-gateway-openai.mjs",
    "user:list": "tsx scripts/user-admin.ts list",
    "user:create": "tsx scripts/user-admin.ts create",
    "user:reset-password": "tsx scripts/user-admin.ts reset-password",
    "user:disable": "tsx scripts/user-admin.ts disable",
    "user:enable": "tsx scripts/user-admin.ts enable"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0"
  }
}
